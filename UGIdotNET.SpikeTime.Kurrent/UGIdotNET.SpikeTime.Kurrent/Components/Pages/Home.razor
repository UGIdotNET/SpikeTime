@page "/"
@using System.Text.Json

@implements IDisposable

@inject KurrentDBClient KurrentDb

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app.

<hr />

<div class="row">
    <div class="col-md-7">
        <table class="table table-striped table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Product</th>
                    <th>Status</th>
                    <th>&nbsp;</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>@order.Customer</td>
                        <td>@order.Product</td>
                        <td>@order.Status</td>
                        <td>
                            @if (order.Status is OrderStatus.Sent)
                            {
                                <button type="button" class="btn btn-outline-primary" @onclick="@(() => AcceptOrder(order))">Accept</button>
                            }
                            else if (order.Status is OrderStatus.Accepted)
                            {
                                <button type="button" class="btn btn-outline-primary" @onclick="@(() => ShipOrder(order))">Ship</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="col-md-5">
        <EditForm Model="order" OnValidSubmit="PlaceOrderAsync">
            <div>
                <label>Customer</label>
                <InputText @bind-Value="order.Customer" class="form-control" />
            </div>
            <div>
                <label>Product</label>
                <InputText @bind-Value="order.Product" class="form-control" />
            </div>

            <div>
                <button type="submit" class="btn btn-primary">Place order</button>
            </div>
        </EditForm>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <h2>Events</h2>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Event</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evt in events)
                {
                    <tr>
                        <td>@evt.Event.Created.ToString()</td>
                        <td>@evt.Event.EventType</td>
                        <td>@System.Text.Encoding.UTF8.GetString(@evt.Event.Data.ToArray())</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


@code {
    private Order order = new();

    private List<Order> orders = [];

    private List<ResolvedEvent> events = [];

    private StreamSubscription? subscription;

    protected override async Task OnInitializedAsync()
    {
        //await LoadEvents();
        await SubscribeAsync();
    }

    private async Task SubscribeAsync()
    {
        subscription = await KurrentDb.SubscribeToStreamAsync(
            "orders",
            FromStream.Start,
            OnEventAppeared
        );
    }

    private Task OnEventAppeared(StreamSubscription sub, ResolvedEvent evt, CancellationToken cancellationToken)
    {
        events.Add(evt);
        return InvokeAsync(StateHasChanged);
    }

    private async Task LoadEvents()
    {
        var result = KurrentDb.ReadStreamAsync(
            Direction.Forwards,
            "orders",
            StreamPosition.Start
        );

        events = await result.ToListAsync();
    }

    private async Task PlaceOrderAsync()
    {
        try
        {
            order.Id = Guid.NewGuid();

            //
            var orderPlaced = new OrderPlaced(order.Id, order.Customer, order.Product);
            var eventData = new EventData(
                Uuid.NewUuid(),
                nameof(OrderPlaced),
                JsonSerializer.SerializeToUtf8Bytes(orderPlaced)
            );

            await KurrentDb.AppendToStreamAsync(
                "orders",
                StreamState.Any,
                [eventData]
            );

            orders.Add(
                new() 
                { 
                    Id = order.Id, 
                    Customer = order.Customer, 
                    Product = order.Product, 
                    Status = OrderStatus.Sent 
                }
            );
        }
        finally
        {
            order = new();
        }
    }

    private async Task AcceptOrder(Order order)
    {
        var orderAccepted = new OrderAccepted(order.Id);
        var eventData = new EventData(
            Uuid.NewUuid(),
            nameof(OrderAccepted),
            JsonSerializer.SerializeToUtf8Bytes(orderAccepted)
        );

        await KurrentDb.AppendToStreamAsync(
            "orders",
            StreamState.Any,
            [eventData]
        );

        order.Status = OrderStatus.Accepted;
    }

    private async Task ShipOrder(Order order)
    {
        var orderShipped = new OrderShipped(order.Id);
        var eventData = new EventData(
            Uuid.NewUuid(),
            nameof(OrderShipped),
            JsonSerializer.SerializeToUtf8Bytes(orderShipped)
        );

        await KurrentDb.AppendToStreamAsync(
            "orders",
            StreamState.Any,
            [eventData]
        );

        order.Status = OrderStatus.Shipped;
    }

    void IDisposable.Dispose()
    {
        subscription?.Dispose();
    }

    record Order
    {
        public Guid Id { get; set; }

        public string Customer { get; set; } = string.Empty;

        public string Product { get; set; } = string.Empty;

        public OrderStatus? Status { get; set; }
    }

    public enum OrderStatus
    {
        Sent,
        Accepted,
        Shipped
    }

    public record OrderPlaced(
        Guid OrderId,
        string Customer,
        string Product
    );

    public record OrderAccepted(Guid OrderId);

    public record OrderShipped(Guid OrderId);
}