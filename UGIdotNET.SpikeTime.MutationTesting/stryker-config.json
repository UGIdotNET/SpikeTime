{
  "stryker-config": {
    "project-info": {
      "name": "UGIdotNET Spike time - mutation testing",
      "module": "ugidotnet.spiketime.mutationtesting",
      "version": "1.0.0"
    },
    "concurrency": 8,
    "mutation-level": "Standard",
    "language-version": "latest",
    "additional-timeout": 5000,
    "mutate": [
      "**/*",
      "!**/Migrations/**",
      "!**/ServiceDefaults/**"
    ],
    "solution": null,
    "configuration": null,
    "target-framework": null,
    "coverage-analysis": "perTest",
    "disable-bail": false,
    "disable-mix-mutants": false,
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "verbosity": "info",
    "reporters": [
      "dots",
      "Html"
    ],
    "since": {
      "enabled": false,
      "ignore-changes-in": [],
      "target": "master"
    },
    "baseline": {
      "enabled": false,
      "provider": "disk",
      "azure-fileshare-url": "",
      "s3-bucket-name": "",
      "s3-endpoint": "",
      "s3-region": "",
      "fallback-version": "master"
    },
    "dashboard-url": "https://dashboard.stryker-mutator.io",
    "test-projects": [],
    "test-case-filter": "",
    "test-runner": null,
    "ignore-mutations": [],
    "ignore-methods": [],
    "report-file-name": "mutation-report",
    "break-on-initial-test-failure": false
  }
}