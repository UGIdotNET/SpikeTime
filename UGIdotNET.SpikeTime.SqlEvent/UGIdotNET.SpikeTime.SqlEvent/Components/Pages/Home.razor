@page "/"
@using System.ComponentModel.DataAnnotations

@inject SqlServerEventsDbContext DbContext

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app.

<hr />

<div class="row">
    <div class="col-md-7">
        <table class="table table-striped table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Product</th>
                    <th>Status</th>
                    <th>&nbsp;</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>@order.Customer</td>
                        <td>@order.Product</td>
                        <td>@order.Status</td>
                        <td>
                            @if (order.Status is Order.OrderStatus.Sent)
                            {
                                <button type="button" class="btn btn-outline-primary" @onclick="@(() => AcceptOrder(order))">Accept</button>
                            }
                            else if (order.Status is Order.OrderStatus.Accepted)
                            {
                                <button type="button" class="btn btn-outline-primary" @onclick="@(() => ShipOrder(order))">Ship</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="col-md-5">
        <EditForm Model="order" OnValidSubmit="PlaceOrderAsync">
            <DataAnnotationsValidator />

            <div class="mb-2">
                <label>Customer</label>
                <InputText @bind-Value="order.Customer" class="form-control" />
                <ValidationMessage For="@(() => order.Customer)" class="text-danger" />
            </div>
            <div class="mb-2">
                <label>Product</label>
                <InputText @bind-Value="order.Product" class="form-control" />
                <ValidationMessage For="@(() => order.Product)" class="text-danger" />
            </div>

            <div class="mb-2">
                <button type="submit" class="btn btn-primary">Place order</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private OrderViewModel order = new();

    private List<OrderViewModel> orders = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadEvents(); 
    }

    private async Task LoadEvents()
    {
        await Task.CompletedTask;
        orders = DbContext.Orders
            .Select(o => new OrderViewModel
                {
                    Id = o.Id,
                    Customer = o.Customer,
                    Product = o.Product,
                    Status = o.Status
                }).ToList();
    }

    private async Task PlaceOrderAsync()
    {
        var entity = new Order
        {
            Customer = order.Customer,
            Product = order.Product,
            Status = Order.OrderStatus.Sent
        };

        DbContext.Add(entity);
        await DbContext.SaveChangesAsync();
    }

    private async Task AcceptOrder(OrderViewModel order)
    {
        var entity = DbContext.Orders.SingleOrDefault(x => x.Id == order.Id);
        entity!.Status = Order.OrderStatus.Accepted;

        await DbContext.SaveChangesAsync();
    }

    private async Task ShipOrder(OrderViewModel order)
    {
        var entity = DbContext.Orders.SingleOrDefault(x => x.Id == order.Id);
        entity!.Status = Order.OrderStatus.Shipped;

        await DbContext.SaveChangesAsync();
    }

    public class OrderViewModel
    {
        public Guid Id { get; set; }

        [Required]
        public string Customer { get; set; } = string.Empty;

        [Required]
        public string Product { get; set; } = string.Empty;

        public Order.OrderStatus? Status { get; set; }
    }
}
